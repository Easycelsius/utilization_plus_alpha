APP_ENV=development
DEFAULT_LLM_PROVIDER=vertex #openai
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
UVICORN_WORKERS=1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-4.3-sonnet
VERTEX_PROJECT=
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-3.1-flash-lite-preview
REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
ENABLE_IN_MEMORY_CACHE=true
CACHE_TTL_SECONDS=300
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
